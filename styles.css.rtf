gap:20px;\
padding:16px;\
border:1px solid var(--border);\
border-radius:14px;\
background:white;\
\}\
\
.year\{\
color:var(--primary);\
font-weight:600;\
width:60px;\
\}\
\
/* TIMELINE */\
.timeline\{\
border-left:2px solid var(--border);\
padding-left:20px;\
\}\
\
.item\{\
margin-bottom:14px;\
position:relative;\
\}\
\
.dot\{\
width:10px;\
height:10px;\
background:var(--primary);\
border-radius:50%;\
position:absolute;\
left:-26px;\
top:6px;\
\}\
\
/* LEXTPT */\
.highlight\{\
background:linear-gradient(135deg,#eef2ff,#f0f9ff);\
padding:30px;\
border-radius:18px;\
\}\
\
.btn\{\
display:inline-block;\
margin-top:12px;\
background:var(--primary);\
color:white;\
padding:10px 16px;\
border-radius:10px;\
text-decoration:none;\
\}\
\
/* FOOTER */\
.footer\{\
text-align:center;\
padding:30px;\
color:var(--muted);\
border-top:1px solid var(--border);\
\}\
\
/* MOBILE */\
@media(max-width:768px)\{\
.hero-grid\{\
grid-template-columns:1fr;\
\}\
\
.grid-2\{\
grid-template-columns:1fr;\
\}\
\
h1\{\
font-size:34px;\
\}\
\}}