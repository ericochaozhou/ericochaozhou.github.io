\f0\fs24 \cf0 :root\{\
--bg:#ffffff;\
--text:#0b1220;\
--muted:#5b6475;\
--primary:#1f4fff;\
--card:#f6f8fc;\
--border:#e6eaf2;\
\}\
\
*\{\
margin:0;\
padding:0;\
box-sizing:border-box;\
\}\
\
body\{\
font-family: Inter, sans-serif;\
background:var(--bg);\
color:var(--text);\
line-height:1.75;\
\}\
\
/* NAV */\
.nav\{\
position:sticky;\
top:0;\
backdrop-filter: blur(14px);\
background:rgba(255,255,255,0.75);\
border-bottom:1px solid var(--border);\
z-index:1000;\
\}\
\
.nav-inner\{\
max-width:1100px;\
margin:auto;\
display:flex;\
justify-content:space-between;\
padding:14px 20px;\
\}\
\
.nav a\{\
margin-left:18px;\
text-decoration:none;\
color:var(--muted);\
font-weight:500;\
\}\
\
.nav a:hover\{\
color:var(--primary);\
\}\
\
.logo\{\
font-weight:700;\
\}\
\
/* HERO */\
.hero\{\
padding:90px 20px;\
\}\
\
.hero-grid\{\
max-width:1100px;\
margin:auto;\
display:grid;\
grid-template-columns:280px 1fr;\
gap:40px;\
align-items:center;\
\}\
\
.profile img\{\
width:100%;\
border-radius:18px;\
box-shadow:0 18px 60px rgba(0,0,0,0.08);\
\}\
\
h1\{\
font-size:44px;\
letter-spacing:-0.02em;\
\}\
\
h2\{\
font-size:28px;\
margin-bottom:20px;\
\}\
\
.affil\{\
