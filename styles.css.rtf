margin-bottom:10px;\
\}\
\
.meta span\{\
display:block;\
color:var(--muted);\
margin:4px 0;\
\}\
\
.tags span\{\
display:inline-block;\
background:#eef2ff;\
color:#1f2a7a;\
padding:6px 10px;\
border-radius:999px;\
margin:4px;\
font-size:13px;\
\}\
\
/* SECTION */\
.section\{\
padding:80px 20px;\
\}\
\
.section.alt\{\
background:var(--card);\
\}\
\
.container\{\
max-width:1100px;\
margin:auto;\
\}\
\
/* GRID */\
.grid-2\{\
display:grid;\
grid-template-columns:repeat(3,1fr);\
gap:18px;\
\}\
\
.card\{\
background:white;\
border:1px solid var(--border);\
padding:20px;\
border-radius:16px;\
\}\
\
/* PUBLICATIONS */\
.pub-list\{\
display:flex;\
flex-direction:column;\
gap:14px;\
\}\
\
.pub\{\
